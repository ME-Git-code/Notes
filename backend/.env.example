# PostgreSQL ulanish manzili (Render PostgreSQL yaratganda avtomatik beriladi)
DATABASE_URL="postgresql://user:password@host:5432/notes?schema=public"

# JWT tokenlarni imzolash uchun maxfiy kalit (production'da uzun random qiymat qo'ying)
JWT_SECRET="change-this-to-a-long-random-string"

# Frontend manzili (vergul bilan bir nechtasini yozish mumkin)
FRONTEND_URL="http://localhost:3000"

# Server porti (Render buni o'zi belgilaydi, lokal uchun 3001)
PORT=3001
